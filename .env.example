# Azure AD application client id used by MSAL
REACT_APP_MSAL_CLIENT_ID=ec39786f-9998-4a43-aef9-2d8148338b0b

# MongoDB connection string for the backend API
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/customerdb?retryWrites=true&w=majority

# Optional port for the backend server
PORT=5000
